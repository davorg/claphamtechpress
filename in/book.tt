<!DOCTYPE html>
<html lang="en">
  <head>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-G9Y7TYL5F7"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-G9Y7TYL5F7');
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <meta name="description" content="[% book_description | html %]" />
    <meta name="author" content="[% book.author.name | html %]" />
    <meta property="og:title" content="[% book.title | html %] - Clapham Technical Press" />
    <meta property="og:description" content="[% book_description | html %]" />
    <meta property="og:type" content="book" />
    <meta property="og:url" content="[% book_url | html %]" />
    <meta property="og:image" content="[% book_image_url | html %]" />
    <meta property="og:image:alt" content="[% book.title | html %] cover" />
    <meta property="og:site_name" content="Clapham Technical Press" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="[% book.title | html %] - Clapham Technical Press" />
    <meta name="twitter:description" content="[% book_description | html %]" />
    <meta name="twitter:image" content="[% book_image_url | html %]" />
    <script type="application/ld+json">[% book_json_ld %]</script>
    <title>[% book.title | html %] - Clapham Technical Press</title>
    <link rel="icon" type="image/x-icon" href="/assets/img/favicon.ico" />
    <script src="https://use.fontawesome.com/releases/v5.13.0/js/all.js" crossorigin="anonymous"></script>
    <link href="https://fonts.googleapis.com/css?family=Merriweather+Sans:400,700" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css?family=Merriweather:400,300,300italic,400italic,700,700italic" rel="stylesheet" type="text/css" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/magnific-popup.js/1.1.0/magnific-popup.min.css" rel="stylesheet" />
    <link href="/css/styles.css" rel="stylesheet" />
  </head>
  <body id="page-top" class="book-page">
    <nav class="navbar navbar-expand-lg navbar-light fixed-top py-3 navbar-scrolled" id="mainNav">
      <div class="container">
        <a class="navbar-brand" href="/">Clapham Technical Press</a>
        <button class="navbar-toggler navbar-toggler-right" type="button" data-toggle="collapse" data-target="#navbarResponsive" aria-controls="navbarResponsive" aria-expanded="false" aria-label="Toggle navigation"><span class="navbar-toggler-icon"></span></button>
        <div class="collapse navbar-collapse" id="navbarResponsive">
          <ul class="navbar-nav ml-auto my-2 my-lg-0">
            <li class="nav-item"><a class="nav-link" href="/#about">About</a></li>
            <li class="nav-item"><a class="nav-link" href="/#services">For Authors</a></li>
            <li class="nav-item"><a class="nav-link" href="/#portfolio">Books</a></li>
            <li class="nav-item"><a class="nav-link" href="/#contact">Contact</a></li>
          </ul>
        </div>
      </div>
    </nav>

    <section class="page-section book-detail">
      <div class="container">
        <div class="row align-items-center">
          <div class="col-lg-5 text-center mb-5 mb-lg-0">
            <img class="img-fluid book-cover" src="/assets/img/portfolio/fullsize/[% book.image | html %].png" alt="[% book.title | html %]" />
          </div>
          <div class="col-lg-7">
            <p class="book-topic">[% book.topic | html %]</p>
            <h1 class="book-title">[% book.title | html %]</h1>
[% IF book.subtitle -%]
            <p class="book-subtitle">[% book.subtitle | html %]</p>
[% END -%]
            <p class="book-author">By [% book.author.name | html %]</p>
[% IF book.coming_soon -%]
            <p class="book-status">Coming soon</p>
[% END -%]
[% IF has_blurb -%]
            <p class="book-blurb">[% book.blurb | html %]</p>
[% ELSE -%]
            <p class="book-blurb">More details about this title will be available soon.</p>
[% END -%]
            <div class="book-actions">
[% IF book.amazon_asin -%]
              <a class="btn btn-primary btn-xl" href="https://www.amazon.com/dp/[% book.amazon_asin | html %]" target="_blank" rel="noopener noreferrer">Amazon US</a>
              <a class="btn btn-primary btn-xl" href="https://www.amazon.co.uk/dp/[% book.amazon_asin | html %]" target="_blank" rel="noopener noreferrer">Amazon UK</a>
[% END -%]
[% IF book.leanpub_slug -%]
              <a class="btn btn-light btn-xl" href="https://leanpub.com/[% book.leanpub_slug | html %]" target="_blank" rel="noopener noreferrer">Leanpub</a>
[% END -%]
            </div>
          </div>
        </div>
      </div>
    </section>

[% IF book.author.bio -%]
    <section class="page-section bg-light book-author-section">
      <div class="container">
        <div class="row justify-content-center">
          <div class="col-lg-8">
            <h2>About [% book.author.name | html %]</h2>
            <hr class="divider my-4" />
            <p class="text-muted">[% book.author.bio | html %]</p>
[% IF book.author.website -%]
            <p><a href="[% book.author.website | html %]" target="_blank" rel="noopener noreferrer">Visit [% book.author.name | html %]'s website</a></p>
[% END -%]
          </div>
        </div>
      </div>
    </section>
[% END -%]

    <section class="page-section book-more">
      <div class="container text-center">
        <h2>More from Clapham Technical Press</h2>
        <hr class="divider my-4" />
        <a class="btn btn-primary btn-xl" href="/#portfolio">Browse Books</a>
      </div>
    </section>

    <footer class="bg-light py-5">
      <div class="container"><div class="small text-center text-muted"><img class="footer-logo" src="/assets/img/logo-800-white.png" alt="Clapham Technical Press"></div></div>
      <div class="container"><div class="small text-center text-muted">Copyright &copy; 2026 - Magnum Solutions Ltd</div></div>
      <div class="container"><div class="small text-center text-muted">Clapham Technical Press is a trading name of Magnum Solutions Ltd</div></div>
    </footer>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.5.1/jquery.min.js"></script>
    <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.0/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-easing/1.4.1/jquery.easing.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/magnific-popup.js/1.1.0/jquery.magnific-popup.min.js"></script>
    <script src="/js/scripts.js"></script>
  </body>
</html>
