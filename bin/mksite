#!/usr/bin/perl

use strict;
use warnings;

use FindBin '$RealBin';
use File::Path 'make_path';
use JSON::PP 'encode_json';
use lib "$RealBin/../lib";

use Template;

use ClaphamTechPress::Schema;
use ClaphamTechPress::IndexPage;

my $tt = Template->new(
  INCLUDE_PATH => 'in',
  OUTPUT_PATH  => 'docs',
);

my @books = ClaphamTechPress::Schema->get_schema->resultset('Book')->search(
  { is_live => 1 },
  { order_by => { -desc => 'pubdate' } },
)->all;

$tt->process('index.tt', { books => \@books, page => ClaphamTechPress::IndexPage->new }, 'index.html')
  or die $tt->error;

make_path('docs/books');

$tt->process('books.tt', { }, 'books/index.html')
  or die $tt->error;

for my $book (@books) {
  my $path = 'books/' . $book->slug;
  make_path($path);

  $tt->process( 'book.tt', { book => $book, }, "$path/index.html",
  ) or die $tt->error;
}
